APP_NAME=X402 App Store
MONGODB_URI=mongodb://127.0.0.1:27017/x402
REDIS_URL=redis://127.0.0.1:6379
# If web is deployed outside Railway, use the public admin-api URL here.
# If both services run on Railway, web can call the public Railway domain or a private host from another Railway service.
ADMIN_API_BASE_URL=http://localhost:4000
ADMIN_API_PORT=4000
WORKER_CONCURRENCY=5
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
