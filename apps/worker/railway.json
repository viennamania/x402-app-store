{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter worker build",
    "watchPatterns": [
      "/apps/worker/**",
      "/packages/**",
      "/tooling/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter worker start",
    "restartPolicyType": "ALWAYS"
  }
}
