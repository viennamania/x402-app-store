{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter admin-api build",
    "watchPatterns": [
      "/apps/admin-api/**",
      "/packages/**",
      "/tooling/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter admin-api start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
